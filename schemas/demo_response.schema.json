{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mergeos-bounties/NokaMan/schemas/demo_response.schema.json",
  "title": "DemoResponse",
  "description": "Stable multi-skill demo payload returned by GET /assess/demo/{lang} and sdk.demo_payload().",
  "type": "object",
  "properties": {
    "language": { "type": "string" },
    "language_name": { "type": "string" },
    "frameworks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skills": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 100 }
    },
    "overall": { "type": "number", "minimum": 0, "maximum": 100 },
    "cefr": { "$ref": "./common.schema.json#/$defs/cefrBand" },
    "framework_bands": { "$ref": "./common.schema.json#/$defs/frameworkBands" },
    "demo_text": { "type": "string" },
    "model": { "type": "string" },
    "integration_version": { "type": "string" }
  },
  "required": [
    "language",
    "language_name",
    "frameworks",
    "skills",
    "overall",
    "cefr",
    "framework_bands",
    "demo_text",
    "model"
  ],
  "additionalProperties": false
}
