{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mergeos-bounties/NokaMan/schemas/common.schema.json",
  "title": "NokaManCommonSchemas",
  "$defs": {
    "cefrBand": {
      "type": "string",
      "enum": ["A1", "A2", "B1", "B2", "C1", "C2"]
    },
    "frameworkBands": {
      "type": "object",
      "properties": {
        "cefr": { "$ref": "#/$defs/cefrBand" },
        "jlpt": { "type": "string" },
        "topik": { "type": "string" },
        "hsk": { "type": "string" },
        "ielts_approx": { "type": "number" },
        "toeic_approx": { "type": "integer" }
      },
      "required": ["cefr"],
      "additionalProperties": false
    },
    "textFeatures": {
      "type": "object",
      "properties": {
        "tokens": { "type": "integer", "minimum": 0 },
        "unique_tokens": { "type": "integer", "minimum": 0 },
        "avg_token_len": { "type": "number", "minimum": 0 },
        "script_bonus": { "type": "number" },
        "connectors": { "type": "integer", "minimum": 0 },
        "sentences": { "type": "integer", "minimum": 0 }
      },
      "required": ["tokens", "unique_tokens", "avg_token_len", "script_bonus", "connectors", "sentences"],
      "additionalProperties": false
    }
  }
}
